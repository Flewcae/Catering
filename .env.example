# Bu dosyayı .env olarak kopyalayıp gerçek değerleri doldurun.
# `.env`, .gitignore'da olduğu için git'e girmez.
SMTP_HOST=
SMTP_PORT=587
SMTP_USE_SSL=true
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=
SMTP_FROM_NAME=Catering

# Firebase Cloud Messaging (push bildirimleri). FIREBASE_CREDENTIALS_JSON, Firebase Console'dan
# indirilen servis hesabı JSON dosyasının tüm içeriği (tek satıra sıkıştırılmış) olmalı.
FIREBASE_PROJECT_ID=
FIREBASE_CREDENTIALS_JSON=
